# Local app login
FIGMA_PLAYGROUND_PASSWORD=change-this-local-password

# Local plugin uploads should not require a shared token.
# Leave this empty/unset for localhost plugin -> Playground usage.
# For production/internal multi-user, do not expose this value in the Figma plugin UI;
# put Playground behind HTTPS + SSO/proxy auth and issue short-lived upload credentials server-side.
# FIGMA_PLUGIN_UPLOAD_TOKEN=

# Optional: override local session/token vault path.
# FIGMA_PLAYGROUND_STORE=data/session_store.local.json
